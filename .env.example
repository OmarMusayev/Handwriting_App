# Model weights (defaults work out of the box)
MODEL_PATH=weights/lstm.pt
TRANSFORMER_CHECKPOINT=weights/transformer.pt

# Data path (LSTM needs strokes.npy + sentences.txt here)
DATA_PATH=./data/

# Session / disk storage
DISK_STORAGE_PATH=./disk

# Generation
MAX_GEN_STEPS=600
N_SAMPLES=5

# Sessions
SESSION_TTL_DAYS=7
MAX_STYLES_PER_SESSION=10
